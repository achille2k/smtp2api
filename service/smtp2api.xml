<?xml version="1.0" encoding="utf-8"?>
<service>
  <id>smtp2api</id>
  <name>SMTP2API</name>
  <description>SMTP to API bridge service.</description>
  <executable>java</executable>
  <arguments>-jar "%BASE%\smtp2api.jar"</arguments>
  <logpath>%BASE%\logs</logpath>
  <log mode="roll" />
  <onfailure action="restart" delay="5000" />
  <stoptimeout>30000</stoptimeout>
  <startmode>Automatic</startmode>
</service>
